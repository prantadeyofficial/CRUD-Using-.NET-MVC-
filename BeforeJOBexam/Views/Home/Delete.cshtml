@model BeforeJOBexam.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-danger text-white py-3">
                    <h3 class="mb-0">
                        <i class="bi bi-trash-fill"></i> Delete Employee
                    </h3>
                </div>

                <div class="card-body">

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                        <div>
                            <strong>Warning!</strong><br />
                            Are you sure you want to permanently delete this employee?
                        </div>
                    </div>

                    <table class="table table-bordered table-hover align-middle">
                        <tbody>
                            <tr>
                                <th width="30%">First Name</th>
                                <td>@Html.DisplayFor(model => model.FirstName)</td>
                            </tr>

                            <tr>
                                <th>Last Name</th>
                                <td>@Html.DisplayFor(model => model.LastName)</td>
                            </tr>

                            <tr>
                                <th>Email</th>
                                <td>@Html.DisplayFor(model => model.Email)</td>
                            </tr>

                            <tr>
                                <th>Phone</th>
                                <td>@Html.DisplayFor(model => model.Phone)</td>
                            </tr>

                            <tr>
                                <th>Hire Date</th>
                                <td>@Html.DisplayFor(model => model.HireDate)</td>
                            </tr>

                            <tr>
                                <th>Department</th>
                                <td>@Html.DisplayFor(model => model.Department)</td>
                            </tr>

                            <tr>
                                <th>Salary</th>
                                <td>
                                    <span class="badge bg-success fs-6">
                                        @Html.DisplayFor(model => model.Salary)
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                </div>

                <div class="card-footer d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash-fill"></i> Delete Employee
                        </button>
                    </form>

                </div>

            </div>

        </div>
    </div>
</div>