@model IEnumerable<BeforeJOBexam.Models.Employee>

@{
    ViewData["Title"] = "Employee Management System";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="display-6 text-primary fw-bold mb-0">Employee Directory</h2>
            <p class="text-muted">Manage company roster and credentials</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Add New Employee
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <span class="me-2"><i class="bi bi-check-circle-fill"></i></span>
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search Box -->
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-2">

                    <div class="col-md-10">
                        <input type="text"
                               name="searchString"
                               value="@ViewData["CurrentFilter"]"
                               class="form-control"
                               placeholder="🔍 Search by First Name, Last Name, Email or Phone..." />
                    </div>

                    <div class="col-md-2 d-grid">
                        <button type="submit" class="btn btn-primary">
                            Search
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>
    <div class="alert alert-info border-0 shadow-sm mb-3">
        <i class="bi bi-info-circle-fill me-2"></i>
        Displaying the <strong>5 most recent</strong> employee records.
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0 text-nowrap">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">@Html.DisplayNameFor(model => model.FirstName)</th>
                            <th>@Html.DisplayNameFor(model => model.LastName)</th>
                            <th>@Html.DisplayNameFor(model => model.Email)</th>
                            <th>@Html.DisplayNameFor(model => model.Phone)</th>
                            @*
                            <th>@Html.DisplayNameFor(model => model.HireDate)</th>
                            <th>@Html.DisplayNameFor(model => model.Department)</th>
                            <th>@Html.DisplayNameFor(model => model.Salary)</th>
                            *@
                            <th class="text-center pe-4">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    No employee records found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold">
                                        @Html.DisplayFor(modelItem => item.FirstName)
                                    </td>

                                    <td>
                                        @Html.DisplayFor(modelItem => item.LastName)
                                    </td>

                                    <td>
                                        <a href="mailto:@item.Email" class="text-decoration-none">
                                            @Html.DisplayFor(modelItem => item.Email)
                                        </a>
                                    </td>

                                    <td>
                                        @Html.DisplayFor(modelItem => item.Phone)
                                    </td>

                                    @*
                                    <td>@item.HireDate.ToString("yyyy-MM-dd")</td>

                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @Html.DisplayFor(modelItem => item.Department)
                                        </span>
                                    </td>

                                    <td class="fw-medium text-success">
                                        ৳ @item.Salary.ToString("N2")
                                    </td>
                                    *@

                                    <td class="text-center pe-4">
                                        <div class="btn-group btn-group-sm">

                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-secondary">
                                                Edit
                                            </a>

                                            <a asp-action="Details"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-info">
                                                Details
                                            </a>

                                            <a asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-danger">
                                                Delete
                                            </a>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>